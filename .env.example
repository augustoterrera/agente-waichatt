# Copiá a .env (dev) o .env.prod (producción). Nunca subas el archivo real.

# Postgres directo. Dev usa el servicio postgres del override; prod apunta al Postgres del VPS.
DATABASE_URL=postgresql://waichatt:waichatt@postgres:5432/agente_waichatt
# DATABASE_URL=postgresql://agente_waichatt:CLAVE@host.docker.internal:5432/agente_waichatt
# DB_POOL_MAX=10

# OpenAI
OPENAI_API_KEY=sk-...
# AGENT_MODEL=gpt-5-mini
# AGENT_REASONING_EFFORT=low
# CLASSIFIER_MODEL=gpt-4.1-mini
# TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Langfuse. Sin keys, usa app/prompts/waichatt.md y funciona sin trazas.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://us.cloud.langfuse.com
# LANGFUSE_PROMPT_NAME=agente-vendedor-waichatt
# LANGFUSE_PROMPT_LABEL=production
# LANGFUSE_PROMPT_CACHE_SECONDS=60

# Transporte. El override local fuerza chatwoot; el override de producción fuerza ycloud.
# CHANNEL=ycloud

# YCloud (producción)
YCLOUD_API_KEY=...
YCLOUD_WHATSAPP_FROM=+5493810000000
YCLOUD_WEBHOOK_SECRET=...
# YCLOUD_BASE_URL=https://api.ycloud.com/v2
# YCLOUD_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Chatwoot (desarrollo)
CHATWOOT_URL=https://tu-chatwoot/
CHATWOOT_ACCOUNT_ID=6
# CHATWOOT_ASSIGNEE_ID=10
CHATWOOT_ACCESS_TOKEN=...
CHATWOOT_WEBHOOK_SECRET=...
# CHATWOOT_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Exige el secret correspondiente al canal activo.
REQUIRE_WEBHOOK_SECRET=true

# Datos oficiales permitidos por el guard anti-alucinación.
# REGISTRO_URL=https://www.waichatt.app/register
# CRM_URL=https://www.waichatt.app
# AGENDA_URL=https://calendar.app.google/TZdc9qpD6w1T4s4K9
# SITIO_URL=https://waichatt.com/
# INSTAGRAM_URL=https://www.instagram.com/waichatt/
# DEMO_PHONE=+5493815225112
# HUMANO_PHONE=+543816814079
# HUMANO_NOMBRE=Julian

# Procesamiento
# HISTORY_LIMIT=16
# DEBOUNCE_SECONDS=5
# DEBOUNCE_RETRY_SECONDS=3
# LOCK_SECONDS=60
# JOB_MAX_RETRIES=5
# OUTBOX_MAX_RETRIES=5
# STALE_PROCESSING_MINUTES=15
# FOLLOWUP_ENABLED=true
# FOLLOWUP_DELAY_HOURS=12
# FOLLOWUP_MAX_AGE_HOURS=24
# CELERY_TIMEZONE=America/Argentina/Tucuman

# El compose configura Redis. Estos defaults sirven al ejecutar fuera de Docker.
# REDIS_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# API admin interna para pausar/reanudar conversaciones.
ADMIN_TOKEN=cambiar-por-token-largo

# Alertas opcionales: errores finales y handoffs comerciales.
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=-1001234567890
# ALERT_PROJECT=agente-waichatt

# Solo desarrollo con docker compose --profile tunnel up.
# NGROK_AUTHTOKEN=...
